# Optional but strongly recommended when exposing the service on a VPS.
NLLW_API_KEY=change-me-to-a-long-random-key
TRANSFLOW_BACKEND_VERSION=0.2.0

# Model/runtime settings.
NLLW_BACKEND=transformers
NLLW_MODEL_SIZE=600M
NLLW_WARMUP_SRCS=zho_Hans,eng_Latn
NLLW_TRANSLATION_CACHE_SIZE=512

# Auto routing: non-Chinese -> Chinese, Chinese -> English.
NLLW_AUTO_TARGET_LANG=zho_Hans
NLLW_AUTO_ALT_TARGET_LANG=eng_Latn

# HTTP/API settings.
NLLW_PORT=18765
NLLW_HOST_PORT=18765
NLLW_MAX_TEXT_CHARS=4000
NLLW_CORS_ORIGINS=*

# Host-side cache note: docker-compose.yml mounts ./model-cache to /models.
# Keep this directory between restarts to avoid re-downloading models.
